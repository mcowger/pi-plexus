{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "Node16",
		"resolveJsonModule": true,
		"noEmit": true,
		"types": ["node"]
	},
	"include": ["index.ts", "src/**/*.ts"]
}
