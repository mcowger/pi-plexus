{
	"name": "@mcowger/pi-plexus",
	"author": "Matt Cowger",
	"version": "0.2.0",
	"description": "Plexus AI provider extension package for pi",
	"license": "MIT",
	"type": "module",
	"keywords": [
		"pi-package",
		"pi",
		"pi-extension",
		"plexus",
		"provider"
	],
	"engines": {
		"bun": ">=1.0"
	},
	"files": [
		"index.ts",
		"src/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"postinstall": "lefthook install",
		"check": "bunx tsc --noEmit",
		"test": "bun test",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"pack:dry-run": "bun pack --dry-run"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"lefthook": "2.1.6"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "0.74.0",
		"@earendil-works/pi-coding-agent": "0.74.0"
	},
	"pi": {
		"extensions": [
			"./index.ts"
		]
	}
}
